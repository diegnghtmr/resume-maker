% ============================================================================
%  ARCHIVO DE REFERENCIAS BibTeX — Ejemplo para IEEE
%  Usar con: \bibliographystyle{IEEEtran} + \bibliography{references}
%
%  REGLAS CLAVE:
%  - Proteger mayúsculas en títulos con llaves: {RAID}, {Linux}, {MIMO}
%  - Usar en-dash (--) para rangos de páginas: pages = {1--6}
%  - Usar abreviaturas de mes sin llaves: month = jan
%  - Usar macros de IEEEabrv.bib para nombres de revistas/conferencias IEEE
%  - Verificar siempre las entradas auto-generadas (IEEE Xplore, Google Scholar)
% ============================================================================

% --- ARTÍCULO DE REVISTA (JOURNAL) ---
@ARTICLE{haykin2009neural,
  author   = {Haykin, Simon},
  title    = {Neural Networks and Learning Machines: A Comprehensive Foundation},
  journal  = {Neural Networks},
  volume   = {22},
  number   = {5},
  pages    = {517--520},
  year     = {2009},
  month    = jul,
}

% --- ARTÍCULO DE CONFERENCIA (INPROCEEDINGS) ---
@INPROCEEDINGS{smith2020example,
  author    = {Smith, John A. and Garc{\'i}a, Mar{\'i}a L.},
  title     = {A Novel Approach to {RAID} Configuration in Virtualized
               Environments},
  booktitle = {Proc. IEEE Int. Conf. Cloud Computing},
  year      = {2020},
  pages     = {112--118},
  month     = oct,
}

